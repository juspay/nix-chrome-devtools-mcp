#!/usr/bin/env bash
# Launch chrome-devtools-mcp using a Chrome-for-Testing binary resolved via
# Nix. Self-contained — no surrounding devshell required. Requires flakes
# (`experimental-features = nix-command flakes` in nix.conf).
#
# Override the nixpkgs source per invocation:
#   NIXPKGS_FLAKE=github:NixOS/nixpkgs/<rev> .../bin/serve
# Or system-wide via `nix registry pin nixpkgs <flake-ref>`.

set -euo pipefail
shopt -s nullglob

nixpkgs="${NIXPKGS_FLAKE:-nixpkgs}"

browsers=$(nix build --no-link --print-out-paths "${nixpkgs}#playwright-driver.browsers")

chrome=""
for c in \
    "$browsers"/chromium-*/chrome-linux64/chrome \
    "$browsers"/chromium-*/chrome-mac-*/"Google Chrome for Testing.app"/Contents/MacOS/"Google Chrome for Testing"; do
    if [[ -x "$c" ]]; then
        chrome="$c"
        break
    fi
done

if [[ -z "$chrome" ]]; then
    echo "mcp-chrome-devtools: no Chrome binary found under $browsers" >&2
    exit 1
fi

exec nix shell "${nixpkgs}#nodejs" --command \
    npx -y chrome-devtools-mcp@0.26.0 \
    --headless=true \
    --isolated=true \
    --executable-path="$chrome"
